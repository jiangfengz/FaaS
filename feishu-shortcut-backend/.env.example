# 服务器配置
PORT=6921

# API配置
API_BASE_URL=http://localhost:6921

# PostgreSQL数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_NAME=postgre
DB_USER=postgres
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Redis配置（异步架构必需）
REDIS_URL=redis://redis:6380/0

# 应用配置
LOG_LEVEL=INFO
CACHE_TTL=3600

# Celery配置
CELERY_BROKER_URL=redis://redis:6380/0
CELERY_RESULT_BACKEND=redis://redis:6380/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=True

# Flower监控面板配置
FLOWER_PORT=5555
FLOWER_BROKER_API=redis://redis:6380/0

# 数据库连接池配置
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# HTTP客户端配置
HTTP_TIMEOUT=900.0
HTTP_MAX_RETRIES=3

# 任务队列配置
TASK_TIMEOUT=3600
TASK_RETRY_DELAY=60
TASK_MAX_RETRIES=3

webhook_url=YOUR_WEBHOOK_URL